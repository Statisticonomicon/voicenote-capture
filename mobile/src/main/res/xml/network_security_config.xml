<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 1 PROTOTYPE network security config.

  Permits cleartext (http://) traffic ONLY to the home-server Tailscale node.
  Every other destination keeps the platform default for targetSdk 34: cleartext
  denied, HTTPS required. Tailscale is the security boundary for this host (see
  ARCHITECTURE.md), so plain HTTP to it is acceptable here.

  NOTE: this hostname is compiled into the APK. The value below is a PLACEHOLDER
  for the public source tree — replace it with your own Tailscale MagicDNS host
  before building, and keep your runtime endpoint URL in Settings on that same
  host so cleartext is allowed only for the one node you trust. If you don't
  use Tailscale, remove this whole config and stay on HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">tailscale-node.your-tailnet.ts.net</domain>
    </domain-config>
</network-security-config>
