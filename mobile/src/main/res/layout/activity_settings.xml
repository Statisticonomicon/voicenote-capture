<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/app_name" android:textSize="20sp" android:textStyle="bold"
            android:paddingBottom="12dp" />

        <!-- Provider choice. Drives which fields below are actually used. -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/provider_label" android:textStyle="bold" />
        <RadioGroup android:id="@+id/providerGroup"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="4dp">
            <RadioButton android:id="@+id/providerSelfHosted"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/provider_self_hosted" />
            <RadioButton android:id="@+id/providerOpenAi"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/provider_openai" />
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="12dp" />

        <!-- Self-hosted provider config -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/self_hosted_section" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/endpoint_label" android:paddingTop="4dp" />
        <EditText android:id="@+id/endpoint" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="@string/endpoint_hint"
            android:inputType="textUri" android:autofillHints="" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/token_label" android:paddingTop="8dp" />
        <EditText android:id="@+id/token" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="@string/token_hint"
            android:inputType="textPassword" android:autofillHints="" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="12dp" />

        <!-- OpenAI provider config -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/openai_section" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/openai_key_label" android:paddingTop="4dp" />
        <EditText android:id="@+id/openAiKey" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="@string/openai_key_hint"
            android:inputType="textPassword" android:autofillHints="" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="12dp" />

        <CheckBox android:id="@+id/mock" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/mock_label" />

        <Button android:id="@+id/save" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="@string/save" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="12dp" />

        <Button android:id="@+id/pickRaw" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/pick_raw" />
        <Button android:id="@+id/pickVault" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/pick_vault" />
        <TextView android:id="@+id/folders" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:paddingTop="8dp" android:textColor="#666666" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="12dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/test_section" android:textStyle="bold" />
        <Button android:id="@+id/importTest" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/import_test" />
    </LinearLayout>
</ScrollView>
