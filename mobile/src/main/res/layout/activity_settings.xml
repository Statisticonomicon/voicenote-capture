<?xml version="1.0" encoding="utf-8"?>
<!--
    VoiceNote Companion — settings screen, redesigned per
    design_handoff_companion_app/instructions to redesign the companion app.md.
    Single vertically-scrolling column on a pure-black background, organised
    into section-label + grouped-card blocks. Same visual language as the
    redesigned watch recording screen (single red accent, "Pure Minimal").
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vnc_bg"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="36dp">

        <!-- ============================ Header ============================ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:paddingStart="2dp">

            <ImageView
                android:layout_width="33dp"
                android:layout_height="26dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_brand_waveform" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/vnc_ink"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.015"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_subtitle"
                    android:textColor="@color/vnc_muted"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingTop="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ====================== Transcription provider ====================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/provider_label"
            android:textColor="@color/vnc_muted"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.13"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="9dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/rowProviderSelfHosted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:background="@drawable/bg_provider_row_selected"
                android:clickable="true"
                android:focusable="true">

                <RadioButton
                    android:id="@+id/radioSelfHosted"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="14dp"
                    android:button="@null"
                    android:background="@drawable/radio_button_drawable"
                    android:clickable="false"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_self_hosted"
                        android:textColor="@color/vnc_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_self_hosted_sub"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:paddingTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowProviderOpenAi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:background="@drawable/bg_provider_row_selected"
                android:clickable="true"
                android:focusable="true">

                <RadioButton
                    android:id="@+id/radioOpenAi"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="14dp"
                    android:button="@null"
                    android:background="@drawable/radio_button_drawable"
                    android:clickable="false"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_openai"
                        android:textColor="@color/vnc_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_openai_sub"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:paddingTop="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ====================== Self-hosted config ====================== -->
        <LinearLayout
            android:id="@+id/sectionSelfHosted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/self_hosted_section"
                android:textColor="@color/vnc_muted"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.13"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="9dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/endpoint_label"
                    android:textColor="@color/vnc_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/endpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/selector_input_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="13dp"
                    android:hint="@string/endpoint_hint"
                    android:textColor="@color/vnc_ink"
                    android:textColorHint="@color/vnc_dim"
                    android:textSize="15.5sp"
                    android:fontFeatureSettings="tnum"
                    android:letterSpacing="-0.01"
                    android:inputType="textUri"
                    android:autofillHints="" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/token_label"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/token_optional_tag"
                        android:textColor="@color/vnc_dim"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="7dp" />
                </LinearLayout>
                <EditText
                    android:id="@+id/token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/selector_input_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="13dp"
                    android:hint="@string/token_hint"
                    android:textColor="@color/vnc_ink"
                    android:textColorHint="@color/vnc_dim"
                    android:textSize="15.5sp"
                    android:inputType="textPassword"
                    android:autofillHints="" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========================= OpenAI config ========================= -->
        <LinearLayout
            android:id="@+id/sectionOpenAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/openai_section"
                android:textColor="@color/vnc_muted"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.13"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="9dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/api_key_label"
                    android:textColor="@color/vnc_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/openAiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/selector_input_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="13dp"
                    android:hint="@string/openai_key_hint"
                    android:textColor="@color/vnc_ink"
                    android:textColorHint="@color/vnc_dim"
                    android:textSize="15.5sp"
                    android:fontFeatureSettings="tnum"
                    android:letterSpacing="-0.01"
                    android:inputType="textPassword"
                    android:autofillHints="" />
            </LinearLayout>
        </LinearLayout>

        <!-- ====================== Save settings ======================
             Placed directly after the provider radio + text-field cards
             above, because those are the only inputs the button actually
             persists. Every other control on this screen (folder pickers,
             switches) saves itself the moment you touch it.
        -->
        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:padding="16dp"
            android:background="@drawable/bg_save_button"
            android:text="@string/save_button"
            android:textColor="@color/vnc_btn_ink"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:textAllCaps="false"
            android:stateListAnimator="@animator/press_scale" />

        <!-- ============================ Storage ============================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/storage_section"
            android:textColor="@color/vnc_muted"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.13"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="9dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/rowRawFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_icon_tile">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_folder_outline" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raw_folder_title"
                        android:textColor="@color/vnc_ink"
                        android:textSize="15.5sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/rawFolderPath"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/vnc_muted"
                        android:textSize="12.5sp"
                        android:paddingTop="2dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="…/Hypomnema/VoiceNotes" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowVaultFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_icon_tile">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_folder_outline" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vault_folder_title"
                        android:textColor="@color/vnc_ink"
                        android:textSize="15.5sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/vaultFolderPath"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/vnc_muted"
                        android:textSize="12.5sp"
                        android:paddingTop="2dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="…/Hypomnema/VoiceNotes" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================ Network ============================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/network_section"
            android:textColor="@color/vnc_muted"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.13"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="9dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/rowWifiOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_only_title"
                        android:textColor="@color/vnc_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_only_subtitle"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:paddingTop="1dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/wifiOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"
                    app:thumbTint="@android:color/white"
                    app:thumbIconTint="@android:color/transparent"
                    app:trackTint="@color/switch_track_tint"
                    app:trackDecorationTint="@android:color/transparent" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowSendPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_icon_tile">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_notif_upload" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/send_pending_now_title"
                    android:textColor="@color/vnc_ink"
                    android:textSize="15.5sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================ Recordings on phone ============================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recordings_section"
            android:textColor="@color/vnc_muted"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.13"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="9dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/rowDeleteAfterUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_after_upload_title"
                        android:textColor="@color/vnc_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_after_upload_subtitle"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:paddingTop="1dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/deleteAfterUpload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"
                    app:thumbTint="@android:color/white"
                    app:thumbIconTint="@android:color/transparent"
                    app:trackTint="@color/switch_track_tint"
                    app:trackDecorationTint="@android:color/transparent" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowExportRecordings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_icon_tile">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_folder_outline" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/export_recordings_title"
                    android:textColor="@color/vnc_ink"
                    android:textSize="15.5sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowDeleteAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_icon_tile">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_trash" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/delete_all_recordings_title"
                    android:textColor="@color/vnc_red_soft"
                    android:textSize="15.5sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================= Test ============================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section"
            android:textColor="@color/vnc_muted"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.13"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="9dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/rowRunTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_play_tile">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_play_triangle" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/run_test_title"
                    android:textColor="@color/vnc_ink"
                    android:textSize="15.5sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vnc_border" />

            <LinearLayout
                android:id="@+id/rowMockSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mock_title"
                        android:textColor="@color/vnc_ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mock_subtitle"
                        android:textColor="@color/vnc_muted"
                        android:textSize="13sp"
                        android:paddingTop="1dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/mock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"
                    app:thumbTint="@android:color/white"
                    app:thumbIconTint="@android:color/transparent"
                    app:trackTint="@color/switch_track_tint"
                    app:trackDecorationTint="@android:color/transparent" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
