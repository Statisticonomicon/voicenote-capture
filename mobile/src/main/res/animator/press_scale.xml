<?xml version="1.0" encoding="utf-8"?>
<!--
    State-list animator for a subtle press-down feel: scales to 0.985 while
    pressed, snaps back on release. 80ms each way - long enough to feel,
    short enough to stay tight. Used on the Save button.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:valueTo="0.985"
                android:duration="80" />
            <objectAnimator
                android:propertyName="scaleY"
                android:valueTo="0.985"
                android:duration="80" />
        </set>
    </item>
    <item>
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:valueTo="1.0"
                android:duration="80" />
            <objectAnimator
                android:propertyName="scaleY"
                android:valueTo="1.0"
                android:duration="80" />
        </set>
    </item>
</selector>
