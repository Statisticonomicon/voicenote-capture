<?xml version="1.0" encoding="utf-8"?>
<!--
    Recording screen (only screen). Layout follows the Option A "Pure Minimal"
    handoff (design_handoff_recording_screen/App screen instructions.md).
    Single full-bleed black circle: status row at top, hero timer + live
    waveform centered, "Press crown to stop" hint at bottom. All content kept
    within the inscribed safe area of the round display.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vnc_bg">

    <!-- Status: blinking red dot + RECORDING label (~36dp from top edge). -->
    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/recordDot"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_record_dot" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording"
            android:textColor="@color/vnc_record_red_soft"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.14" />
    </LinearLayout>

    <!-- Center: hero timer + waveform (vertically centered). -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/timerView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/vnc_ink"
            android:textSize="33sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:fontFeatureSettings="tnum"
            tools:ignore="HardcodedText" />

        <com.notaricus.voicenote.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:layout_marginTop="9dp" />
    </LinearLayout>

    <!-- Hint: crown glyph + "Press crown to stop" (~32dp from bottom edge). -->
    <LinearLayout
        android:id="@+id/hintRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/crownGlyph"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="5dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_crown" />

        <TextView
            android:id="@+id/hintView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/press_crown_to_stop"
            android:textColor="@color/vnc_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</FrameLayout>
